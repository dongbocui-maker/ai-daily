---
export interface DemoItem {
  slug: string;
  addedDate: string;
  repo: string;
  repoUrl: string;
  liveUrl: string;
  title: string;
  intro: string;
  purpose?: string | null;
  keyFeatures: string[];
}

interface Props {
  item: DemoItem;
}

const { item } = Astro.props;
---
<article class="group relative bg-white border border-accent-gray-200 rounded-sm overflow-hidden
                hover:border-accent-purple hover:shadow-[0_0_0_2px_rgba(161,0,255,0.06)]
                transition-all">
  {/* 整卡可点 = 打开 Live Demo（新窗口） */}
  <a
    href={item.liveUrl}
    target="_blank"
    rel="noopener noreferrer"
    aria-label={`打开 ${item.title} Live Demo`}
    class="absolute inset-0 z-10"
  ></a>

  <div class="relative p-6 lg:p-8 pointer-events-none">

    {/* Header：标题 + repo */}
    <div class="mb-5 pb-5 border-b border-accent-gray-100">
      <h2 class="text-2xl lg:text-3xl font-extrabold tracking-tight mb-2
                 group-hover:text-accent-purple transition-colors">
        {item.title}
      </h2>
      <div class="text-sm text-accent-gray-500 font-mono">{item.repo}</div>
    </div>

    {/* 简介 + Purpose 两栏（桌面）/ 堆叠（移动） */}
    <div class={`grid gap-6 mb-6 ${item.purpose ? 'lg:grid-cols-2' : 'grid-cols-1'}`}>
      {/* 简介 */}
      <div>
        <div class="text-[10px] font-bold uppercase tracking-wider text-accent-purple mb-2">
          简介
        </div>
        <p class="text-sm lg:text-[15px] text-accent-ink leading-relaxed">
          {item.intro}
        </p>
      </div>

      {/* Purpose（可选） */}
      {item.purpose && (
        <div>
          <div class="text-[10px] font-bold uppercase tracking-wider text-accent-purple mb-2">
            Purpose
          </div>
          <p class="text-sm lg:text-[15px] text-accent-ink leading-relaxed">
            {item.purpose}
          </p>
        </div>
      )}
    </div>

    {/* Key Features */}
    {item.keyFeatures && item.keyFeatures.length > 0 && (
      <div class="mb-6 pl-4 border-l-2 border-accent-purple/30">
        <div class="text-[10px] font-bold uppercase tracking-wider text-accent-purple mb-3">
          Key Features
        </div>
        <ul class="space-y-2">
          {item.keyFeatures.map((f) => (
            <li class="text-sm lg:text-[15px] text-accent-ink leading-relaxed flex gap-2">
              <span class="text-accent-purple flex-shrink-0 mt-1">▪</span>
              <span>{f}</span>
            </li>
          ))}
        </ul>
      </div>
    )}

    {/* 双按钮 */}
    <div class="flex flex-wrap items-center gap-3 pt-4 border-t border-accent-gray-100">
      <span class="inline-flex items-center gap-2 px-5 py-2.5 bg-accent-purple text-white
                   text-sm font-semibold rounded-sm
                   group-hover:bg-accent-purple/90 transition-colors">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
          <path d="M6.3 2.841A1.5 1.5 0 004 4.11V15.89a1.5 1.5 0 002.3 1.269l9.344-5.89a1.5 1.5 0 000-2.538L6.3 2.84z"/>
        </svg>
        打开 Live Demo
        <span class="ml-1">→</span>
      </span>

      {/* GitHub 按钮——单独点（pointer-events 重新启用 + z 提高在覆盖 a 之上） */}
      <a
        href={item.repoUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="relative z-20 pointer-events-auto inline-flex items-center gap-2 px-4 py-2.5
               border border-accent-gray-300 text-accent-ink text-sm font-semibold rounded-sm
               hover:border-accent-ink hover:bg-accent-gray-50 transition-colors"
      >
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.44 9.8 8.21 11.39.6.11.82-.26.82-.58 0-.29-.01-1.04-.02-2.05-3.34.73-4.04-1.61-4.04-1.61-.55-1.39-1.34-1.76-1.34-1.76-1.09-.75.08-.73.08-.73 1.21.09 1.84 1.24 1.84 1.24 1.07 1.84 2.81 1.31 3.5 1 .11-.78.42-1.31.76-1.61-2.66-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.12-.3-.54-1.52.12-3.18 0 0 1.01-.32 3.3 1.23a11.5 11.5 0 016 0c2.29-1.55 3.3-1.23 3.3-1.23.66 1.66.24 2.88.12 3.18.77.84 1.24 1.91 1.24 3.22 0 4.61-2.81 5.63-5.49 5.93.43.37.81 1.1.81 2.22 0 1.61-.01 2.9-.01 3.29 0 .32.22.7.83.58C20.56 21.8 24 17.31 24 12c0-6.63-5.37-12-12-12z"/>
        </svg>
        GitHub
      </a>

      {/* 添加日期，小字 */}
      <span class="ml-auto text-xs text-accent-gray-400">
        {item.addedDate}
      </span>
    </div>

  </div>
</article>
