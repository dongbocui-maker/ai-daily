---
import GitHubBoard from './GitHubBoard.astro';
import type { YearlyBoardData } from '../lib/github';

interface Props {
  data: YearlyBoardData;
}
const { data } = Astro.props;
---
{/* 年度顶层 Tab：新生爆款 vs 增长最快 */}
<div data-subtabs="yearly-mode">
  <div class="inline-flex bg-emerald-50 p-1 rounded mb-6 gap-1 border border-emerald-200">
    <button
      type="button"
      data-subtab="yearly-newborn"
      aria-selected="true"
      class="px-4 py-1.5 text-sm font-semibold bg-accent-purple text-white rounded transition-colors"
    >
      🆕 今年新生爆款
    </button>
    <button
      type="button"
      data-subtab="yearly-fastest"
      aria-selected="false"
      class="px-4 py-1.5 text-sm font-semibold text-accent-gray-600 rounded hover:bg-accent-gray-100 transition-colors"
    >
      🚀 今年最热项目
    </button>
  </div>
</div>

<div data-subpanel="yearly-newborn">
  <p class="text-sm text-accent-gray-500 mb-4">
    📍 今年（{new Date().getFullYear()} 年）新创建的项目中 stars 最多的 Top 50。反映"今年诞生的爆款"。
  </p>
  <GitHubBoard data={data.newborn} scopeId="yn" showPeriodStars={false} />
</div>

<div data-subpanel="yearly-fastest" class="hidden">
  <p class="text-sm text-accent-gray-500 mb-4">
    📍 今年仍在活跃维护（pushed in {new Date().getFullYear()}）且 stars 最多的项目 Top 50。反映"今年最受关注的高热度仓库"。
  </p>
  <GitHubBoard data={data.fastest_growing} scopeId="yf" showPeriodStars={false} />
</div>
