---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import learnData from '../../data/learn.json';

const base = import.meta.env.BASE_URL;

// 学习板块条目——从 src/data/learn.json 读取。
// 新增课程只需改 JSON，不动源码。说明见 docs/learn-template.md。
const items = learnData.items.map((it) => ({
  // 外部链接保留原样，内部链接拼上 base path
  href: it.external ? it.href : `${base.replace(/\/$/, '')}${it.href}`,
  tag: it.tag,
  title: it.title,
  desc: it.desc,
  meta: it.meta,
  external: it.external ?? false,
}));
---
<Base title="学习中心" description="AI 相关的学习计划、课程笔记、技术资料汇总。">
  <Header />
  <main class="flex-1">
    <section class="bg-accent-ink text-white py-12 lg:py-16">
      <div class="container-x">
        <span class="badge bg-accent-purple text-white mb-4">LEARNING HUB</span>
        <h1 class="text-3xl lg:text-4xl font-extrabold tracking-tight mb-3">🎓 学习中心</h1>
        <p class="text-base lg:text-lg text-accent-gray-300 max-w-3xl">
          AI 相关的学习计划、课程笔记、技术资料汇总。独立于每日 AI 资讯主题，聚焦深度学习和长期价值。
        </p>
        {items.length > 0 && (
          <p class="mt-3 text-sm text-accent-gray-400">共 {items.length} 项内容</p>
        )}
      </div>
    </section>

    <section class="py-12 lg:py-16">
      <div class="container-x max-w-5xl">
        {items.length === 0 ? (
          <div class="text-center py-16 text-accent-gray-500">
            <p>暂无学习内容。</p>
          </div>
        ) : (
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {items.map((it) => (
              <a
                href={it.href}
                class="block px-6 py-6 bg-white border border-accent-gray-200 rounded-sm
                       hover:border-accent-purple hover:shadow-md transition-all group"
              >
                <span class="inline-block text-xs px-2 py-0.5 bg-accent-purple/10 text-accent-purple rounded mb-3">
                  {it.tag}
                </span>
                <h3 class="text-xl font-extrabold tracking-tight mb-2 group-hover:text-accent-purple transition-colors">
                  {it.title}
                </h3>
                <p class="text-sm text-accent-gray-600 leading-relaxed mb-4">
                  {it.desc}
                </p>
                <div class="flex items-center gap-2 text-xs text-accent-gray-500">
                  {it.meta.map((m, i) => (
                    <>
                      {i > 0 && <span>·</span>}
                      <span>{m}</span>
                    </>
                  ))}
                  <span class="ml-auto text-accent-purple group-hover:translate-x-1 transition-transform">→</span>
                </div>
              </a>
            ))}
          </div>
        )}

        <p class="mt-12 text-center text-sm text-accent-gray-500">
          更多学习内容陆续添加中。
        </p>
      </div>
    </section>
  </main>
  <Footer />
</Base>
