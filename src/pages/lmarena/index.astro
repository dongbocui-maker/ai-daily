---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import fs from 'node:fs';
import path from 'node:path';

// 加载所有 snapshot，按日期排序取最新
const snapshotsDir = path.resolve('./src/data/lmarena/snapshots');
const snapshotFiles = fs.existsSync(snapshotsDir)
  ? fs.readdirSync(snapshotsDir).filter(f => f.endsWith('.json')).sort()
  : [];

const latestFile = snapshotFiles.length > 0 ? snapshotFiles[snapshotFiles.length - 1] : null;
const previousFile = snapshotFiles.length > 1 ? snapshotFiles[snapshotFiles.length - 2] : null;

const latest = latestFile
  ? JSON.parse(fs.readFileSync(path.join(snapshotsDir, latestFile), 'utf-8'))
  : null;
const previous = previousFile
  ? JSON.parse(fs.readFileSync(path.join(snapshotsDir, previousFile), 'utf-8'))
  : null;

// 计算月度对比
type DeltaInfo = { type: 'baseline' | 'new' | 'up' | 'down' | 'same'; delta?: number };
function computeDelta(modelName: string, currentRank: number): DeltaInfo {
  if (!previous) return { type: 'baseline' };
  const prev = previous.models?.find((m: any) => m.name === modelName);
  if (!prev) return { type: 'new' };
  const d = prev.rank - currentRank;
  if (d > 0) return { type: 'up', delta: d };
  if (d < 0) return { type: 'down', delta: Math.abs(d) };
  return { type: 'same' };
}

// 退出 Top 50 的模型（在上月榜单但本月不在）
const exitedModels = previous && latest
  ? previous.models.filter((p: any) => !latest.models.find((c: any) => c.name === p.name))
  : [];

// 厂商分布统计
const orgCounts: Record<string, number> = {};
if (latest) {
  for (const m of latest.models) {
    orgCounts[m.org] = (orgCounts[m.org] || 0) + 1;
  }
}
const orgRanking = Object.entries(orgCounts).sort((a, b) => b[1] - a[1]);

// 厂商颜色映射
const orgColors: Record<string, string> = {
  'Anthropic': 'bg-orange-100 text-orange-800',
  'OpenAI': 'bg-emerald-100 text-emerald-800',
  'Google': 'bg-blue-100 text-blue-800',
  'Meta': 'bg-blue-100 text-blue-700',
  'xAI': 'bg-gray-900 text-white',
  'DeepSeek': 'bg-purple-100 text-purple-800',
  'Alibaba': 'bg-red-100 text-red-800',
  'Moonshot': 'bg-indigo-100 text-indigo-800',
  'Baidu': 'bg-rose-100 text-rose-800',
  'Tencent': 'bg-cyan-100 text-cyan-800',
  'Z.ai': 'bg-violet-100 text-violet-800',
  'Bytedance': 'bg-yellow-100 text-yellow-800',
  'Xiaomi': 'bg-orange-100 text-orange-700',
  'Ant Group': 'bg-blue-100 text-blue-800',
  'MiniMax': 'bg-pink-100 text-pink-800',
  'Nvidia': 'bg-green-100 text-green-800',
  'Inception AI': 'bg-slate-100 text-slate-800',
  'Amazon': 'bg-yellow-100 text-yellow-900',
};
function orgColor(org: string) {
  return orgColors[org] || 'bg-accent-gray-100 text-accent-gray-700';
}

const base = import.meta.env.BASE_URL;
---
<Base title="LMArena 全球大模型排行榜" description="基于 lmarena.ai 实测数据的全球大模型 Top 50 排行榜，每月更新一次。">
  <Header />
  <main class="flex-1">
    <!-- Hero -->
    <section class="bg-accent-ink text-white py-12 lg:py-16">
      <div class="container-x">
        <span class="badge bg-accent-purple text-white mb-4">LMARENA LEADERBOARD</span>
        <h1 class="text-3xl lg:text-4xl font-extrabold tracking-tight mb-3">🏆 LMArena 全球大模型 Top 50</h1>
        <p class="text-base lg:text-lg text-accent-gray-300 max-w-3xl">
          基于 <a href="https://lmarena.ai/leaderboard" target="_blank" rel="noopener" class="underline hover:text-accent-purple">lmarena.ai</a> 真实人类盲测对战数据的全球大模型排行榜。每月 1 日自动更新一次。
        </p>
        {latest && (
          <p class="mt-4 text-sm text-accent-gray-400">
            📅 最新快照：<span class="text-white font-medium">{latest.snapshotDate}</span>
            · 共观察 {latest.totalModelsObserved} 个模型
            · 展示 Top {latest.totalModelsShown}
            {latest.isBaseline && <span class="ml-2 px-2 py-0.5 bg-accent-purple/30 text-accent-purple-light rounded text-xs">📊 基线快照（首期，无月度对比）</span>}
          </p>
        )}
      </div>
    </section>

    {!latest ? (
      <section class="py-16">
        <div class="container-x text-center text-accent-gray-500">
          <p>暂无数据。</p>
        </div>
      </section>
    ) : (
      <>
        <!-- 厂商分布卡片 -->
        <section class="py-8 bg-accent-gray-50 border-b border-accent-gray-100">
          <div class="container-x">
            <h2 class="text-sm font-bold uppercase tracking-wider text-accent-gray-500 mb-3">📊 Top 50 厂商分布</h2>
            <div class="flex flex-wrap gap-2">
              {orgRanking.map(([org, count]) => (
                <span class={`px-3 py-1.5 rounded-full text-sm font-medium ${orgColor(org)}`}>
                  {org} <span class="opacity-70 text-xs ml-1">×{count}</span>
                </span>
              ))}
            </div>
          </div>
        </section>

        <!-- 排行榜 -->
        <section class="py-12">
          <div class="container-x">
            <!-- 桌面端表格 -->
            <div class="hidden md:block overflow-x-auto bg-white border border-accent-gray-200 rounded-sm">
              <table class="w-full">
                <thead class="bg-accent-gray-50 border-b-2 border-accent-gray-200">
                  <tr class="text-left text-xs font-bold uppercase tracking-wider text-accent-gray-600">
                    <th class="px-4 py-3 w-16 text-center">排名</th>
                    <th class="px-4 py-3">模型</th>
                    <th class="px-4 py-3 w-32">厂商</th>
                    <th class="px-4 py-3">优势赛道</th>
                    <th class="px-4 py-3 w-24 text-center">月度变化</th>
                  </tr>
                </thead>
                <tbody>
                  {latest.models.map((m: any) => {
                    const delta = computeDelta(m.name, m.rank);
                    return (
                      <tr class="border-b border-accent-gray-100 hover:bg-accent-gray-50 transition-colors">
                        <td class="px-4 py-3 text-center">
                          <span class={`inline-block min-w-[2rem] font-bold ${
                            m.rank <= 3 ? 'text-accent-purple text-lg' :
                            m.rank <= 10 ? 'text-accent-ink' : 'text-accent-gray-700'
                          }`}>
                            {m.rank === 1 ? '🥇' : m.rank === 2 ? '🥈' : m.rank === 3 ? '🥉' : ('#' + m.rank)}
                          </span>
                        </td>
                        <td class="px-4 py-3">
                          <span class="font-mono text-sm font-semibold text-accent-ink">{m.name}</span>
                        </td>
                        <td class="px-4 py-3">
                          <span class={`inline-block px-2 py-0.5 rounded text-xs font-medium ${orgColor(m.org)}`}>
                            {m.org}
                          </span>
                        </td>
                        <td class="px-4 py-3">
                          <div class="flex flex-wrap gap-1.5">
                            {m.highlight.length === 0 ? (
                              <span class="text-xs text-accent-gray-400">综合 #{m.rank}</span>
                            ) : (
                              m.highlight.map((h: any) => (
                                <span class={`text-xs px-2 py-0.5 rounded ${
                                  h.isTop10
                                    ? 'bg-accent-purple/10 text-accent-purple font-medium'
                                    : 'bg-accent-gray-100 text-accent-gray-600'
                                }`}>
                                  {h.isTop10 && '🏆 '}{h.label} #{h.rank}
                                </span>
                              ))
                            )}
                          </div>
                        </td>
                        <td class="px-4 py-3 text-center text-xs">
                          {delta.type === 'baseline' && <span class="text-accent-gray-400">📊 基线</span>}
                          {delta.type === 'new' && <span class="text-accent-purple font-bold">🆕 新增</span>}
                          {delta.type === 'up' && <span class="text-green-600 font-bold">↑ {delta.delta}</span>}
                          {delta.type === 'down' && <span class="text-rose-500 font-bold">↓ {delta.delta}</span>}
                          {delta.type === 'same' && <span class="text-accent-gray-400">—</span>}
                        </td>
                      </tr>
                    );
                  })}
                </tbody>
              </table>
            </div>

            <!-- 移动端卡片 -->
            <div class="md:hidden space-y-3">
              {latest.models.map((m: any) => {
                const delta = computeDelta(m.name, m.rank);
                return (
                  <div class="bg-white border border-accent-gray-200 rounded-sm p-4">
                    <div class="flex items-center justify-between mb-2">
                      <div class="flex items-center gap-2">
                        <span class={`font-bold text-lg ${m.rank <= 3 ? 'text-accent-purple' : 'text-accent-ink'}`}>
                          {m.rank === 1 ? '🥇' : m.rank === 2 ? '🥈' : m.rank === 3 ? '🥉' : ('#' + m.rank)}
                        </span>
                        <span class={`px-2 py-0.5 rounded text-xs font-medium ${orgColor(m.org)}`}>
                          {m.org}
                        </span>
                      </div>
                      <div class="text-xs">
                        {delta.type === 'baseline' && <span class="text-accent-gray-400">📊</span>}
                        {delta.type === 'new' && <span class="text-accent-purple font-bold">🆕</span>}
                        {delta.type === 'up' && <span class="text-green-600 font-bold">↑{delta.delta}</span>}
                        {delta.type === 'down' && <span class="text-rose-500 font-bold">↓{delta.delta}</span>}
                      </div>
                    </div>
                    <div class="font-mono text-sm font-semibold text-accent-ink mb-2 break-all">
                      {m.name}
                    </div>
                    <div class="flex flex-wrap gap-1">
                      {m.highlight.length === 0 ? (
                        <span class="text-xs text-accent-gray-400">综合 #{m.rank}</span>
                      ) : (
                        m.highlight.map((h: any) => (
                          <span class={`text-xs px-2 py-0.5 rounded ${
                            h.isTop10
                              ? 'bg-accent-purple/10 text-accent-purple font-medium'
                              : 'bg-accent-gray-100 text-accent-gray-600'
                          }`}>
                            {h.isTop10 && '🏆 '}{h.label} #{h.rank}
                          </span>
                        ))
                      )}
                    </div>
                  </div>
                );
              })}
            </div>

            <!-- 退出 Top 50 -->
            {exitedModels.length > 0 && (
              <div class="mt-8 p-5 bg-accent-gray-50 border border-accent-gray-200 rounded-sm">
                <h3 class="font-bold text-sm uppercase tracking-wider text-accent-gray-600 mb-2">
                  ⛔ 本月退出 Top 50（共 {exitedModels.length} 个）
                </h3>
                <div class="flex flex-wrap gap-2 text-xs">
                  {exitedModels.map((m: any) => (
                    <span class="px-2 py-1 bg-white border border-accent-gray-200 rounded">
                      <span class="font-mono">{m.name}</span>
                      <span class="text-accent-gray-500 ml-1">(上月 #{m.rank})</span>
                    </span>
                  ))}
                </div>
              </div>
            )}
          </div>
        </section>

        <!-- 说明 -->
        <section class="py-8 bg-accent-gray-50 border-t border-accent-gray-100">
          <div class="container-x max-w-3xl">
            <h3 class="font-bold text-sm uppercase tracking-wider text-accent-gray-600 mb-3">📖 说明</h3>
            <div class="prose prose-sm text-accent-gray-700 space-y-2">
              <p>
                <strong>数据来源</strong>：<a href="https://lmarena.ai/leaderboard" target="_blank" rel="noopener" class="text-accent-purple hover:underline">lmarena.ai 官方排行榜</a>，基于全球用户对模型对战的盲测投票。排名为相对位次（rank position），不是 ELO 分数。
              </p>
              <p>
                <strong>优势赛道生成规则</strong>：从该模型在 27 个评测维度（综合 / 难题 / 代码 / 数学 / 创意写作 / 中文 / 各行业等）中：
              </p>
              <ul class="list-disc ml-6 space-y-1">
                <li>🏆 <strong>优先显示 Top 10 的核心维度</strong>（最多 3 个）</li>
                <li>不足 3 个时，用该模型自身相对最强的维度补足（不带 🏆）</li>
                <li>核心能力（难题/代码/数学/写作等）优先于行业 / 小语种维度</li>
              </ul>
              <p>
                <strong>月度变化</strong>：与上月快照对比。<span class="text-green-600 font-bold">↑</span> 上升 / <span class="text-rose-500 font-bold">↓</span> 下降 / 🆕 新进 Top 50 / 📊 基线（首期或上月不在 Top 50）。
              </p>
              <p>
                <strong>更新频率</strong>：每月 1 日 09:00（北京时间）自动从 lmarena.ai 抓取最新数据并发布。
              </p>
            </div>
          </div>
        </section>
      </>
    )}
  </main>
  <Footer />
</Base>
