---
import { formatStars, relativeTime, languageColors, type GitHubRepo } from '../lib/github';

interface Props {
  repo: GitHubRepo;
  showPeriodStars?: boolean; // 显示本期增量
}

const { repo, showPeriodStars = true } = Astro.props;
const langColor = repo.language ? languageColors[repo.language] ?? '#888' : null;
---
<article class="border border-accent-gray-200 bg-white p-5 transition-all hover:border-accent-purple hover:shadow-[0_0_0_2px_rgba(161,0,255,0.06)]">
  <div class="flex items-baseline gap-3 mb-2">
    <span class="text-xs font-bold text-accent-gray-400 tabular-nums">#{repo.rank}</span>
    <a
      href={repo.url}
      target="_blank"
      rel="noopener"
      class="text-base lg:text-lg font-bold tracking-tight hover:text-accent-purple transition-colors break-all"
    >
      {repo.name}
    </a>
  </div>

  {repo.description_zh && (
    <p class="text-sm lg:text-[15px] text-accent-ink leading-relaxed mb-2">
      {repo.description_zh}
    </p>
  )}
  {repo.description && (
    <p class={`text-xs lg:text-sm text-accent-gray-500 leading-relaxed mb-3 ${repo.description_zh ? 'italic' : ''}`}>
      {repo.description}
    </p>
  )}

  <div class="flex flex-wrap items-center gap-x-4 gap-y-1.5 text-xs text-accent-gray-500">
    {repo.language && (
      <span class="flex items-center gap-1.5">
        <span class="w-2.5 h-2.5 rounded-full" style={`background:${langColor}`}></span>
        <span>{repo.language}</span>
      </span>
    )}
    <span class="flex items-center gap-1 font-semibold text-accent-ink">
      <svg class="w-3.5 h-3.5 text-amber-500" fill="currentColor" viewBox="0 0 20 20">
        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.286 3.957a1 1 0 00.95.69h4.16c.969 0 1.371 1.24.588 1.81l-3.366 2.446a1 1 0 00-.364 1.118l1.287 3.957c.3.921-.755 1.688-1.54 1.118l-3.366-2.446a1 1 0 00-1.176 0l-3.366 2.446c-.784.57-1.838-.197-1.539-1.118l1.287-3.957a1 1 0 00-.364-1.118L2.072 9.384c-.783-.57-.38-1.81.588-1.81h4.16a1 1 0 00.95-.69l1.286-3.957z"></path>
      </svg>
      {formatStars(repo.stars)}
      {showPeriodStars && repo.stars_period !== undefined && repo.stars_period > 0 && (
        <span class="text-emerald-600 font-medium">+{formatStars(repo.stars_period)}</span>
      )}
    </span>
    {repo.forks !== undefined && repo.forks > 0 && (
      <span class="flex items-center gap-1">
        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 16 16">
          <path d="M5 5.372v.878c0 .414.336.75.75.75h4.5a.75.75 0 0 0 .75-.75v-.878a2.25 2.25 0 1 1 1.5 0v.878a2.25 2.25 0 0 1-2.25 2.25h-1.5v2.128a2.251 2.251 0 1 1-1.5 0V8.5h-1.5A2.25 2.25 0 0 1 3.5 6.25v-.878a2.25 2.25 0 1 1 1.5 0ZM5 3.25a.75.75 0 1 0-1.5 0 .75.75 0 0 0 1.5 0Zm6.75.75a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm-3 8.75a.75.75 0 1 0-1.5 0 .75.75 0 0 0 1.5 0Z"></path>
        </svg>
        {formatStars(repo.forks)}
      </span>
    )}
    {repo.pushed_at && (
      <span>更新于 {relativeTime(repo.pushed_at)}</span>
    )}
  </div>

  {repo.topics && repo.topics.length > 0 && (
    <div class="flex flex-wrap gap-1.5 mt-3">
      {repo.topics.slice(0, 5).map((t) => (
        <span class="px-2 py-0.5 text-[11px] bg-accent-gray-100 text-accent-gray-600 rounded">{t}</span>
      ))}
    </div>
  )}
</article>
