---
import { getCollection } from 'astro:content';
import Base from '../../../layouts/Base.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';

export async function getStaticPaths() {
  const docs = await getCollection('seven-pillars');
  const sorted = docs.sort((a, b) => a.data.order - b.data.order);
  return sorted.map((doc, idx) => ({
    params: { slug: doc.data.slug },
    props: {
      doc,
      prev: idx > 0 ? sorted[idx - 1] : null,
      next: idx < sorted.length - 1 ? sorted[idx + 1] : null,
    },
  }));
}

const { doc, prev, next } = Astro.props;
const base = import.meta.env.BASE_URL;
---
<Base title={`${doc.data.docNum} · ${doc.data.title}`} description={`Agentic AI 七柱深度研究 · ${doc.data.title}`}>
  <Header />
  <main class="flex-1">
    {/* 面包屑 */}
    <nav class="container-x py-4 text-sm text-accent-gray-500">
      <a href={`${base}learn/`} class="hover:text-accent-purple">学习中心</a>
      <span class="mx-2">/</span>
      <a href={`${base}learn/agentic-ai-seven-pillars/`} class="hover:text-accent-purple">Agentic AI 七柱</a>
      <span class="mx-2">/</span>
      <span class="text-accent-gray-700">{doc.data.docNum}</span>
    </nav>

    {/* 文档头 */}
    <header class={`container-x py-6 mb-4 pillar-${doc.data.docColor}`}>
      <div class="border-l-4 pl-6 pillar-border">
        <div class="text-xs font-bold tracking-widest text-accent-gray-500 uppercase">{doc.data.docNum}</div>
        <h1 class="text-3xl lg:text-4xl font-extrabold tracking-tight mt-2 text-accent-ink">{doc.data.title}</h1>
        <p class="mt-3 text-sm text-accent-gray-500">
          {doc.data.words ? <><span>{doc.data.words}</span><span class="mx-2">·</span></> : null}
          飞书原文：<a href={`https://my.feishu.cn/docx/${doc.data.feishuToken}`} target="_blank" rel="noopener" class="text-accent-purple hover:underline">my.feishu.cn/docx/{doc.data.feishuToken.slice(0, 12)}…</a>
        </p>
      </div>
    </header>

    {/* 正文（保留原始换行、ASCII 图）*/}
    <article class="container-x max-w-4xl pb-8">
      <pre class="whitespace-pre-wrap break-words font-sans text-[15px] leading-[1.75] text-accent-gray-800 m-0">{doc.body}</pre>
    </article>

    {/* 上下篇导航 */}
    <nav class="container-x max-w-4xl mt-8 py-8 border-t border-accent-gray-200">
      <div class="flex flex-col md:flex-row justify-between gap-3">
        {prev ? (
          <a href={`${base}learn/agentic-ai-seven-pillars/${prev.data.slug}/`} class="flex-1 px-5 py-4 border border-accent-gray-200 hover:border-accent-purple transition group bg-white">
            <div class="text-xs text-accent-gray-500 mb-1">← 上一篇</div>
            <div class="text-sm font-semibold group-hover:text-accent-purple">{prev.data.docNum} · {prev.data.title}</div>
          </a>
        ) : <div class="flex-1"></div>}
        <a href={`${base}learn/agentic-ai-seven-pillars/`} class="px-5 py-4 border-2 border-accent-purple bg-accent-purple text-white hover:bg-accent-purple-deep transition flex items-center justify-center font-semibold">
          ⇧ 返回目录
        </a>
        {next ? (
          <a href={`${base}learn/agentic-ai-seven-pillars/${next.data.slug}/`} class="flex-1 px-5 py-4 border border-accent-gray-200 hover:border-accent-purple transition group text-right bg-white">
            <div class="text-xs text-accent-gray-500 mb-1">下一篇 →</div>
            <div class="text-sm font-semibold group-hover:text-accent-purple">{next.data.docNum} · {next.data.title}</div>
          </a>
        ) : <div class="flex-1"></div>}
      </div>
    </nav>
  </main>
  <Footer />
</Base>

<style is:global>
  .pillar-foundation .pillar-border { border-color: #6B7280; }
  .pillar-p1 .pillar-border { border-color: #A100FF; }
  .pillar-p2 .pillar-border { border-color: #00C8FF; }
  .pillar-p3 .pillar-border { border-color: #00E676; }
  .pillar-p4 .pillar-border { border-color: #FF3B30; }
  .pillar-p5 .pillar-border { border-color: #FF9500; }
  .pillar-p6 .pillar-border { border-color: #E5B900; }
  .pillar-p7 .pillar-border { border-color: #5856D6; }
  .pillar-conclusion .pillar-border { border-color: #1A1A1A; }
</style>
