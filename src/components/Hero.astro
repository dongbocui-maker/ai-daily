---
import { formatDateZh, dayOfWeekZh } from '../lib/data';
import type { DailyReport } from '../lib/data';
import AudioPlayer from './AudioPlayer.astro';

const report = Astro.props.report as DailyReport;
// title 如果就是日期本身说明没解析出真正的标题，用静态名代替
const headline = report.title && report.title !== report.date
  ? report.title
  : 'AI 行业每日速览';
const totalItems = report.sections.reduce((sum, s) => sum + s.items.length, 0);
---
<section class="relative bg-accent-ink text-white overflow-hidden">
  <!-- 装饰渐变 -->
  <div class="absolute inset-0 opacity-60 pointer-events-none">
    <div class="absolute -top-40 -right-40 w-[600px] h-[600px] rounded-full bg-accent-purple blur-[120px]"></div>
    <div class="absolute bottom-0 -left-40 w-[500px] h-[500px] rounded-full bg-accent-purple-deep blur-[140px] opacity-50"></div>
  </div>

  <div class="container-x relative py-10 lg:py-14">
    <div class="flex flex-wrap items-center gap-3 mb-4 text-xs font-medium tracking-wide">
      <span class="px-2.5 py-0.5 bg-accent-purple text-white">DAILY</span>
      <span class="text-accent-gray-300">{formatDateZh(report.date)}</span>
      <span class="text-accent-gray-500">·</span>
      <span class="text-accent-gray-300">{dayOfWeekZh(report.date)}</span>
    </div>

    <h1 class="text-3xl lg:text-4xl font-extrabold tracking-tight max-w-4xl mb-3 text-balance leading-tight">
      {headline}
    </h1>

    <p class="text-base lg:text-lg text-accent-gray-300 max-w-3xl leading-relaxed">
      {report.summary || `今日收录 ${totalItems} 条资讯，涵盖 ${report.sections.length} 个板块。向下滚动查看本期速览。`}
    </p>

    {report.audio && <AudioPlayer audio={report.audio} date={report.date} />}

    <div class="mt-6 flex flex-wrap items-center gap-x-5 gap-y-2">
      {report.sections.map((s) => (
        <a
          href={`#${s.key}`}
          class="flex items-center gap-1.5 text-sm font-medium text-accent-gray-400
                 hover:text-white transition-colors group"
        >
          <span class="text-base">{s.emoji}</span>
          <span class="border-b border-transparent group-hover:border-accent-purple-light pb-0.5">
            {s.label}
          </span>
          <span class="text-xs text-accent-gray-500">({s.items.length})</span>
        </a>
      ))}
    </div>
  </div>
</section>
