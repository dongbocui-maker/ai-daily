---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import SectionBlock from '../components/SectionBlock.astro';
import Closing from '../components/Closing.astro';
import DateNav from '../components/DateNav.astro';
import { loadLatest } from '../lib/data';

const latest = loadLatest();
if (!latest) {
  return Astro.redirect('/about/');
}
---
<Base title={`${latest.title} · ${latest.date}`} description={latest.summary}>
  <Header currentDate={latest.date} />
  <main class="flex-1">
    <Hero report={latest} />
    <DateNav currentDate={latest.date} />
    {latest.sections.map((section) => (
      <SectionBlock section={section} />
    ))}
    <Closing paragraphs={latest.closing} />
  </main>
  <Footer />
</Base>
