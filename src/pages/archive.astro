---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { loadAll, formatDateZh, dayOfWeekZh } from '../lib/data';

const reports = loadAll();
const base = import.meta.env.BASE_URL;
---
<Base title="历史归档" description="所有历史 AI 日报归档">
  <Header />
  <main class="flex-1">
    <section class="bg-accent-ink text-white py-16 lg:py-20">
      <div class="container-x">
        <span class="badge bg-accent-purple text-white mb-4">ARCHIVE</span>
        <h1 class="text-h1 mb-4">历史归档</h1>
        <p class="text-lg text-accent-gray-300 max-w-3xl">
          共 {reports.length} 期日报，按时间倒序排列。
        </p>
      </div>
    </section>

    <section class="py-16">
      <div class="container-x">
        <ul class="space-y-2">
          {reports.map((r) => (
            <li>
              <a
                href={`${base}d/${r.date}/`}
                class="block py-5 px-6 -mx-6 transition-colors hover:bg-accent-gray-50 group"
              >
                <div class="flex items-baseline gap-6">
                  <div class="flex-shrink-0 w-32">
                    <span class="block font-mono text-xs text-accent-gray-500">{r.date}</span>
                    <span class="block text-xs text-accent-gray-500">{dayOfWeekZh(r.date)}</span>
                  </div>
                  <div class="flex-1 min-w-0">
                    <h3 class="font-semibold text-lg group-hover:text-accent-purple transition-colors">
                      {r.title}
                    </h3>
                    {r.summary && (
                      <p class="text-sm text-accent-gray-700 mt-1 line-clamp-2">
                        {r.summary}
                      </p>
                    )}
                  </div>
                  <span class="hidden md:flex items-center gap-1 text-xs text-accent-gray-500">
                    {r.sections.reduce((sum, s) => sum + s.items.length, 0)} 条
                  </span>
                  <span class="text-accent-gray-300 group-hover:text-accent-purple group-hover:translate-x-1 transition-all">→</span>
                </div>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>
  </main>
  <Footer />
</Base>
