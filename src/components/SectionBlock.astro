---
import type { Section } from '../lib/data';
const section = Astro.props.section as Section;

const accentBgs: Record<string, string> = {
  news: 'bg-category-news',
  enterprise: 'bg-category-enterprise',
  coding: 'bg-category-coding',
  report: 'bg-category-report',
};

function hostnameOf(url?: string): string | null {
  if (!url) return null;
  try {
    return new URL(url).hostname.replace(/^www\./, '');
  } catch {
    return null;
  }
}
---
<section id={section.key} class="py-16 lg:py-20 scroll-mt-20">
  <div class="container-x">
    <div class="flex items-baseline gap-4 mb-10 pb-4 border-b border-accent-gray-100">
      <span class="text-3xl">{section.emoji}</span>
      <h2 class="text-h2">{section.label}</h2>
      <span class="ml-auto badge bg-accent-gray-100 text-accent-gray-700">
        {section.items.length} 条
      </span>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {section.items.map((item, idx) => {
        const host = hostnameOf(item.url);
        return (
          <article class="card-news flex flex-col">
            <div class="flex items-start justify-between gap-3 mb-3">
              <span class={`badge ${accentBgs[section.key]} text-white`}>
                {String(idx + 1).padStart(2, '0')}
              </span>
              {item.source && (
                <span class="text-xs text-accent-gray-500 font-medium">{item.source}</span>
              )}
            </div>

            <h3 class="text-h3 mb-3 text-balance leading-snug">
              {item.url ? (
                <a
                  href={item.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="hover:text-accent-purple transition-colors"
                >
                  {item.title}
                </a>
              ) : (
                item.title
              )}
            </h3>

            <p class="text-accent-gray-700 leading-relaxed">
              {item.body}
            </p>

            {item.insight && (
              <div class="insight-block">
                <span class="block text-xs uppercase tracking-wider font-bold text-accent-purple mb-1">
                  行业启示
                </span>
                {item.insight}
              </div>
            )}

            {item.url && (
              <div class="mt-5 pt-4 border-t border-accent-gray-100 flex items-center justify-between">
                <a
                  href={item.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-1.5 text-sm font-semibold text-accent-purple
                         hover:text-accent-purple-deep transition-colors group/link"
                >
                  <span>点击查看更多</span>
                  <span class="transition-transform group-hover/link:translate-x-1">→</span>
                </a>
                {host && (
                  <span class="text-xs text-accent-gray-500 font-mono truncate max-w-[180px]">
                    {host}
                  </span>
                )}
              </div>
            )}
          </article>
        );
      })}
    </div>
  </div>
</section>
