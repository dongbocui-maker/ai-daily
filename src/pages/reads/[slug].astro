---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import AudioPlayer from '../../components/AudioPlayer.astro';
import { listSlugs, loadRead } from '../../lib/reads';

export async function getStaticPaths() {
  return listSlugs().map((slug) => ({
    params: { slug },
    props: { article: loadRead(slug) },
  }));
}

const { article } = Astro.props;
if (!article) throw new Error('Article not found');

const base = import.meta.env.BASE_URL;

// markdown-like 渲染：把 \n 转成段落，保留加粗
function renderMd(md: string): string {
  return md
    .split('\n\n')
    .map((para) => {
      const trimmed = para.trim();
      if (!trimmed) return '';
      // 标题
      if (trimmed.startsWith('### ')) {
        return `<h3 class="text-lg lg:text-xl font-bold mt-8 mb-3">${escapeHtml(trimmed.slice(4))}</h3>`;
      }
      if (trimmed.startsWith('## ')) {
        return `<h2 class="text-xl lg:text-2xl font-extrabold mt-10 mb-4">${escapeHtml(trimmed.slice(3))}</h2>`;
      }
      // 引用
      if (trimmed.startsWith('> ')) {
        return `<blockquote class="border-l-4 border-accent-purple pl-4 my-4 italic text-accent-gray-700">${formatInline(trimmed.slice(2))}</blockquote>`;
      }
      // 列表
      if (trimmed.startsWith('- ')) {
        const items = trimmed
          .split('\n')
          .filter((l) => l.startsWith('- '))
          .map((l) => `<li class="mb-1">${formatInline(l.slice(2))}</li>`)
          .join('');
        return `<ul class="list-disc list-outside ml-6 mb-4 space-y-1">${items}</ul>`;
      }
      // 普通段落
      return `<p class="mb-4 leading-relaxed">${formatInline(trimmed)}</p>`;
    })
    .join('\n');
}

function escapeHtml(s: string): string {
  return s
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;');
}

function formatInline(s: string): string {
  // 先转义 HTML
  let out = escapeHtml(s);
  // 加粗
  out = out.replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>');
  return out;
}
---
<Base title={`${article.titleZh} · 精读`} description={article.summary}>
  <Header />
  <main class="flex-1">
    {/* 顶部：标题 + 元信息 */}
    <section class="bg-accent-ink text-white py-12 lg:py-16">
      <div class="container-x max-w-4xl">
        <a href={`${base}reads/`} class="inline-block text-sm text-accent-gray-400 hover:text-white mb-4 transition-colors">
          ← 返回精读
        </a>
        <span class="badge bg-accent-purple text-white mb-4">DEEP READ</span>
        <h1 class="text-3xl lg:text-4xl font-extrabold tracking-tight mb-2 leading-tight">
          {article.titleZh}
        </h1>
        {article.titleEn && (
          <p class="text-base lg:text-lg text-accent-gray-400 italic mb-4">{article.titleEn}</p>
        )}
        <div class="flex items-baseline gap-3 mb-6 flex-wrap text-sm">
          <span class="font-medium text-white">{article.author}</span>
          {article.authorTitle && <span class="text-accent-gray-400">{article.authorTitle}</span>}
          {article.publishDate && (
            <span class="text-accent-gray-500">· 发布于 {article.publishDate}</span>
          )}
          <span class="text-accent-gray-500">· 收录于 {article.savedDate}</span>
        </div>
        <div class="flex flex-wrap gap-2">
          <a
            href={article.originalUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-4 py-2 bg-accent-purple hover:bg-accent-purple-deep text-white text-sm font-medium rounded-sm transition-colors"
          >
            🔗 阅读英文原文
          </a>
          {article.deckPdfUrl && (
            <a
              href={`${base}${article.deckPdfUrl}`}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-4 py-2 bg-accent-purple hover:bg-accent-purple-deep text-white text-sm font-medium rounded-sm transition-colors"
            >
              📊 精读概要 PPT
            </a>
          )}
        </div>

        {article.audio && (
          <AudioPlayer audio={article.audio} date={article.slug} />
        )}
      </div>
    </section>

    {/* 内容主体 */}
    <section class="py-12 lg:py-16">
      <div class="container-x max-w-3xl">
        {/* 1. 一句话核心观点 */}
        <div class="mb-10 p-6 bg-accent-purple/5 border-l-4 border-accent-purple">
          <h2 class="text-sm font-bold uppercase tracking-wider text-accent-purple mb-2">📌 一句话核心</h2>
          <p class="text-lg lg:text-xl font-medium leading-relaxed">{article.summary}</p>
        </div>

        {/* 2. 核心观点 bullets */}
        <div class="mb-10">
          <h2 class="text-2xl font-extrabold mb-4">💡 核心观点</h2>
          <ol class="space-y-3 list-decimal list-outside ml-6">
            {article.keyPoints.map((p) => (
              <li class="leading-relaxed pl-1" set:html={formatInline(p)}></li>
            ))}
          </ol>
        </div>

        {/* 3. 启示与思考（钢铁虾视角） */}
        {article.insight && (
          <div class="mb-10 p-6 bg-accent-gray-50 border border-accent-gray-200">
            <h2 class="text-2xl font-extrabold mb-3">🎯 启示与思考</h2>
            <p class="leading-relaxed text-accent-gray-800">{article.insight}</p>
          </div>
        )}

        {/* 4. 完整中文解读 */}
        <div class="mb-10">
          <h2 class="text-2xl font-extrabold mb-4">📜 中文解读</h2>
          <div class="prose prose-lg max-w-none" set:html={renderMd(article.summaryZh)}></div>
        </div>

        {/* 5. 金句精选 */}
        {article.quotes && article.quotes.length > 0 && (
          <div class="mb-10">
            <h2 class="text-2xl font-extrabold mb-4">💎 金句精选</h2>
            <div class="space-y-4">
              {article.quotes.map((q) => (
                <div class="p-5 bg-white border-l-4 border-accent-purple">
                  {q.en && (
                    <p class="italic text-accent-gray-700 mb-2 leading-relaxed">"{q.en}"</p>
                  )}
                  <p class="text-accent-ink font-medium leading-relaxed">「{q.zh}」</p>
                </div>
              ))}
            </div>
          </div>
        )}

        {/* 6. 标签 */}
        {article.tags.length > 0 && (
          <div class="mb-6 pt-6 border-t border-accent-gray-200">
            <div class="flex flex-wrap gap-2">
              {article.tags.map((t) => (
                <span class="text-sm px-3 py-1 bg-accent-gray-100 text-accent-gray-700 rounded-sm">
                  #{t}
                </span>
              ))}
            </div>
          </div>
        )}

        {/* 底部回链 */}
        <div class="mt-10 pt-6 border-t border-accent-gray-200 flex items-center justify-between flex-wrap gap-3">
          <a href={`${base}reads/`} class="text-accent-purple hover:text-accent-purple-deep font-medium">
            ← 返回精读列表
          </a>
          <div class="flex items-center gap-4 flex-wrap">
            {article.deckPdfUrl && (
              <a
                href={`${base}${article.deckPdfUrl}`}
                target="_blank"
                rel="noopener noreferrer"
                class="text-accent-purple hover:text-accent-purple-deep font-medium"
              >
                📊 精读概要 PPT →
              </a>
            )}
            <a
              href={article.originalUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="text-accent-purple hover:text-accent-purple-deep font-medium"
            >
              阅读英文原文 →
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Base>
