---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Hero from '../../components/Hero.astro';
import SectionBlock from '../../components/SectionBlock.astro';
import Closing from '../../components/Closing.astro';
import DateNav from '../../components/DateNav.astro';
import { listDates, loadDate } from '../../lib/data';

export async function getStaticPaths() {
  return listDates().map((date) => ({
    params: { date },
    props: { report: loadDate(date) },
  }));
}

const { report } = Astro.props;
if (!report) throw new Error('Report not found');
---
<Base title={`${report.title} · ${report.date}`} description={report.summary}>
  <Header currentDate={report.date} />
  <main class="flex-1">
    <Hero report={report} />
    <DateNav currentDate={report.date} />
    {report.sections.map((section) => (
      <SectionBlock section={section} />
    ))}
    <Closing paragraphs={report.closing} />
  </main>
  <Footer />
</Base>
